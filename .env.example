# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "Excel Sequence Generator"
NEXT_PUBLIC_APP_DESCRIPTION = "Generate Excel sequence formulas, row labels, and CSV previews for bulk numbering without dragging."
NEXT_PUBLIC_APP_LOGO = "/logo.svg"
NEXT_PUBLIC_APP_PREVIEW_IMAGE = "/preview.svg"
NEXT_PUBLIC_DEFAULT_LOCALE = "en"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "light"

# database
DATABASE_PROVIDER = "sqlite"
DATABASE_URL = "file:data/local.db"
DB_SCHEMA_FILE = "./src/config/db/schema.sqlite.ts"
DB_MIGRATIONS_OUT = "./src/config/db/migrations_sqlite"
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""
